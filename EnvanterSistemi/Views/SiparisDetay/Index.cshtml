@model IEnumerable<SiparisDetaylar>

@{
    ViewData["Title"] = "Sipariş Detaylar";
}

<style>
    body {
        background: linear-gradient(135deg, #dfe9f3, #ffffff);
        min-height: 100vh;
    }

    .table-modern tbody tr:nth-child(odd) {
        background-color: #ffffff;
    }

    .table-modern tbody tr:nth-child(even) {
        background-color: #f8f9fc;
    }

    .table-modern tbody tr:hover {
        background-color: rgba(78,115,223,0.12);
    }

    .badge-active {
        background-color: #1cc88a;
        padding: 6px 14px;
        border-radius: 50px;
        color: white;
        font-size: 12px;
    }

    .badge-passive {
        background-color: #e74a3b;
        padding: 6px 14px;
        border-radius: 50px;
        color: white;
        font-size: 12px;
    }

    .btn-modern {
        border-radius: 50px;
        transition: background 0.3s ease, color 0.3s ease;
    }

    .container-custom {
        padding: 3rem 4rem;
    }

    .text-center-custom h2 {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .text-center-custom p {
        font-size: 1rem;
        color: #6c757d;
    }

    .form-container {
        margin-top: 3rem;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 14px;
    }
</style>

<div class="container container-custom">
    <div class="text-center text-center-custom">
        <h2 class="fw-bold display-6">📦 Sipariş Detayları</h2>
        <p class="text-muted">Bu siparişin tüm detaylarını aşağıda görebilirsiniz.</p>
    </div>

    <div class="form-container">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th>Sipariş No</th>
                    <th>Ürün Adı</th>
                    <th>Adet</th>
                    <th>Fiyat</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">#@item.SiparisId</td>
                        <td>@item.Urun.UrunAdi</td>
                        <td>@item.Adet</td>
                        <td>@item.Fiyat</td>
                        <td class="text-end">
                            <a asp-action="Delete" asp-route-id="@item.SiparisDetayId" class="btn btn-sm btn-danger btn-modern">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form>
            <a asp-controller="Siparis" asp-action="Index" class="btn btn-sm btn-secondary btn-modern">Geri</a>
        </form>
    </div>
</div>