@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    body {
        background: linear-gradient(135deg, #dfe9f3, #ffffff);
    }

    .card-3d {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        transition: all 0.4s ease;
        transform-style: preserve-3d;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        position: relative;
        overflow: hidden;
    }

       /*  .card-3d:hover {
            transform: rotateX(2deg) rotateY(-2deg) translateY(0px) scale(1.02);
        } */

        /* Parlayan ışık efekti */
        .card-3d::before {
            content: "";
            position: absolute;
            top: -100%;
            left: -100%;
            width: 200%;
            height: 200%;
            background: linear-gradient( 120deg, transparent, rgba(255,255,255,0.5), transparent );
            transform: rotate(25deg);
            transition: 0.6s;
        }

        .card-3d:hover::before {
            top: 100%;
            left: 100%;
        }

    .icon-3d {
        font-size: 50px;
        transition: transform 0.4s ease;
    }

    .card-3d:hover .icon-3d {
        transform: scale(1.2) rotate(10deg);
    }

    .btn-modern {
        border-radius: 50px;
        transition: all 0.3s ease;
    }

        .btn-modern:hover {
            transform: scale(1.05);
        }

</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5">🚀 Yönetim Paneli</h1>
        <p class="text-muted">Sisteminizi modern arayüzle yönetin</p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">📦</div>
                <h5 class="fw-bold">Siparişler</h5>
                <p class="text-muted small">Tüm siparişleri görüntüleyin</p>
                <a asp-controller="Siparis" asp-action="Index"
                   class="btn btn-primary btn-modern w-100">
                    Görüntüle
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">🏷️</div>
                <h5 class="fw-bold">Kategori</h5>
                <p class="text-muted small">Yeni kategori ekleyin</p>
                <a asp-controller="Kategori" asp-action="Index"
                   class="btn btn-warning btn-modern w-100">
                    Kategori Ekle
                </a>
            </div>
        </div>

        <!-- Ürün Ekle -->
        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">➕</div>
                <h5 class="fw-bold">Ürün Ekle</h5>
                <p class="text-muted small">Yeni ürün oluştur</p>
                <a asp-controller="Urun" asp-action="Index"
                   class="btn btn-success btn-modern w-100">
                    Ürün Ekle
                </a>
            </div>
        </div>

        <!-- Ürünleri Listele -->
        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">📋</div>
                <h5 class="fw-bold">Ürün Listesi</h5>
                <p class="text-muted small">Tüm ürünleri görüntüle</p>
                <a asp-controller="Urunler" asp-action="Index"
                   class="btn btn-outline-success btn-modern w-100">
                    Ürünleri Gör
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">🚚</div>
                <h5 class="fw-bold">Tedarikçi</h5>
                <p class="text-muted small">Tedarikçi yönetimi</p>
                <a asp-controller="Tedarikci" asp-action="Index"
                   class="btn btn-info btn-modern w-100">
                    Tedarikçi Ekle
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-3d p-4 text-center">
                <div class="icon-3d mb-3">🛍️</div>
                <h5 class="fw-bold">Sepet</h5>
                <p class="text-muted small">Sepeti görüntüle</p>
                <a asp-controller="Sepet" asp-action="Index"
                   class="btn btn-dark btn-modern w-100">
                    Sepete Git
                </a>
            </div>
        </div>

    </div>
</div>