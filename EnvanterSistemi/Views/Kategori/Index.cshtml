@model IEnumerable<Kategoriler>

@{
    ViewData["Title"] = "Kategoriler";
}

<style>
    body {
        background: linear-gradient(135deg, #dfe9f3, #ffffff);
    }

    .table-modern tbody tr:nth-child(odd) {
        background-color: #ffffff;
    }

    .table-modern tbody tr:nth-child(even) {
        background-color: #f8f9fc;
    }

    .table-modern tbody tr:hover {
        background-color: rgba(78,115,223,0.12);
    }

    .badge-active {
        background-color: #1cc88a;
        padding: 6px 14px;
        border-radius: 50px;
        color: white;
        font-size: 12px;
    }

    .badge-passive {
        background-color: #e74a3b;
        padding: 6px 14px;
        border-radius: 50px;
        color: white;
        font-size: 12px;
    }

    .btn-modern {
        border-radius: 50px;
        transition: background 0.3s ease, color 0.3s ease;
    }
</style>

<div class="container py-5">

    <div class="text-center mb-4">
        <h2 class="fw-bold display-6">📂 Kategori Yönetimi</h2>
        <p class="text-muted">Tüm kategorileri buradan yönetebilirsiniz</p>
    </div>

    <div class="p-4">

        <div class="d-flex justify-content-end mb-3">
            <a asp-action="Create" class="btn btn-primary btn-modern">
                + Yeni Kategori
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-modern align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Kategori Adı</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.KategoriId</td>

                            <td>
                                @item.KategoriAdi
                            </td>

                            <td>
                                @if (item.AktifMi)
                                {
                                    <span class="badge-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-passive">Pasif</span>
                                }
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@item.KategoriId"
                                   class="btn btn-sm btn-secondary btn-modern">
                                    Düzenle
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.KategoriId"
                                   class="btn btn-sm btn-danger btn-modern">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>