@model Kategoriler

@{
    ViewData["Title"] = "Yeni Kategori";
}

<h2>Yeni Kategori</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">

        <label asp-for="KategoriAdi"></label>
        <input asp-for="KategoriAdi" class="form-control" />
        <span asp-validation-for="KategoriAdi" class="text-danger"></span>

        <label asp-for="AktifMi" class="form-label mb-1">Aktif</label>
        <select asp-for="AktifMi" class="form-select form-select-sm w-auto">
            <option value="true">Evet</option>
        </select>
        <span asp-validation-for="AktifMi" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}